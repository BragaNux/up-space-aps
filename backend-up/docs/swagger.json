{
  "openapi": "3.0.0",
  "info": {
    "title": "Up Espaço API",
    "version": "1.0.0",
    "description": "Documentação mínima das rotas API."
  },
  "servers": [{ "url": "http://localhost:8000" }],
  "paths": {
    "/api/student": {
      "get": {
        "summary": "Get student",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/student/presence": {
      "patch": {
        "summary": "Update presence",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PresenceRequest" }
            }
          }
        },
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/timeline": {
      "get": {
        "summary": "List timeline",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/posts": {
      "get": {
        "summary": "List posts",
        "responses": { "200": { "description": "OK" } }
      },
      "post": {
        "summary": "Create post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreatePostRequest" }
            }
          }
        },
        "responses": { "201": { "description": "Created" } }
      }
    },
    "/api/posts/{id}/like": {
      "post": {
        "summary": "Like post",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "204": { "description": "No Content" } }
      }
    },
    "/api/posts/{id}/bookmark": {
      "post": {
        "summary": "Bookmark post",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "204": { "description": "No Content" } }
      }
    },
    "/api/events": {
      "get": {
        "summary": "List events",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/api/events/{id}/rsvp": {
      "post": {
        "summary": "RSVP event",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": { "204": { "description": "No Content" } }
      }
    }
  },
  "components": {
    "schemas": {
      "CreatePostRequest": {
        "type": "object",
        "properties": {
          "student_id": { "type": "integer" },
          "content": { "type": "string" }
        }
      },
      "PresenceRequest": {
        "type": "object",
        "properties": {
          "status": { "type": "string" }
        }
      }
    }
  }
}
